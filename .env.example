# Choose ONE auth path:

# Option A: Google AI Studio API key
GOOGLE_API_KEY=your-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Choose ONE auth path:

# Option A: Google AI Studio API key
GOOGLE_API_KEY=your-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Option B: Vertex AI project (leave GOOGLE_API_KEY unset if using this)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional model overrides
CREATIVE_TEXT_MODEL=gemini-3.1-flash-lite
CREATIVE_IMAGE_MODEL=gemini-3.1-flash-image
CREATIVE_TTS_MODEL=gemini-3.1-flash-tts-preview

# Required for news + field-update tools. Free tier key from https://newsapi.org
NEWS_API_KEY=your-newsapi-key-here

# Required for local news fetching. Free tier key from https://worldnewsapi.com
WORLDNEWS_API_KEY=your-worldnews-key-here
